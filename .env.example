# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_PORT=3001

# ─── Database ────────────────────────────────────────────────────────────────
# Option A: full URL (Railway / PlanetScale)
DATABASE_URL=mysql://triplog:triplog123@localhost:3306/triplog
# Option B: individual fields (docker-compose)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=triplog
DB_USER=triplog
DB_PASSWORD=triplog123
MYSQL_ROOT_PASSWORD=rootpassword

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ─── Google Maps ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Email (Brevo / SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Redis (optional, for queues) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
